---
import "../styles/global.css";
import ClientRuntime from "../islands/ClientRuntime.jsx";
import { ANALYTICS } from "../config/analytics";
import { SITE } from "../config/site";
import { withBase } from "../utils/basePath";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = SITE.name,
  description = SITE.defaultDescription,
  ogImage = SITE.defaultOgImage,
  noindex = false,
} = Astro.props as Props;

const pageTitle =
  title === SITE.name || title.includes(SITE.name) ? title : `${title} | ${SITE.name}`;
const isGitHubPagesBuild = import.meta.env.BASE_URL.startsWith("/Imperio_web");
const deploymentOrigin =
  isGitHubPagesBuild ? "https://earlrititi-lang.github.io" : SITE.url;
const canonicalUrl = new URL(Astro.url.pathname, deploymentOrigin).toString();
const ogImageUrl = new URL(withBase(ogImage), deploymentOrigin).toString();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <meta name="x-runtime-stack" content="astro,google-tag,cloudflare-ready" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" type="image/png" href={withBase("/images/logo-redv2.png")} />
    <link rel="shortcut icon" type="image/png" href={withBase("/images/logo-redv2.png")} />
    <meta name="theme-color" content="#c1121f" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://db.onlinewebfonts.com/c/35da23d6d7d68a326080792c63a6251b?family=FS+Rosa+Black"
      rel="stylesheet"
    />
    {ANALYTICS.gtmId && (
      <script is:inline>
        {`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({"gtm.start":new Date().getTime(),event:"gtm.js"});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!=="dataLayer"?"&l="+l:"";j.async=true;j.src="https://www.googletagmanager.com/gtm.js?id="+i+dl;f.parentNode.insertBefore(j,f);})(window,document,"script","dataLayer","${ANALYTICS.gtmId}");`}
      </script>
    )}
    {!ANALYTICS.gtmId && ANALYTICS.googleTagId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ANALYTICS.googleTagId}`}></script>
        <script is:inline>
          {`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}window.gtag=window.gtag||gtag;gtag("js",new Date());gtag("config","${ANALYTICS.googleTagId}");`}
        </script>
      </>
    )}
  </head>
  <body>
    {ANALYTICS.gtmId && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${ANALYTICS.gtmId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
          title="Google Tag Manager"
        ></iframe>
      </noscript>
    )}
    <slot />
    <div id="imperio-scrollbar" aria-hidden="true">
      <div id="imperio-scrollbar-track">
        <div id="imperio-scrollbar-thumb"></div>
      </div>
    </div>
    <ClientRuntime client:load />
  </body>
</html>
