---
import CollectionCard from "../../components/CollectionCard.astro";
import PageShell from "../../layouts/PageShell.astro";
import { getCollection, render } from "astro:content";

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getCollection("rutas");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<PageShell
  title={entry.data.title}
  description={entry.data.seoDescription ?? entry.data.summary}
  eyebrow="Ruta"
  heading={entry.data.title}
  summary={entry.data.intro}
  summaryMuted
  narrow
>
  <section class="section content">
    <Content />
  </section>

  {entry.data.items && (
    <section class="section content">
      <h3>Lecturas sugeridas</h3>
      <div class="grid">
        {entry.data.items.map((item) => (
          <CollectionCard
            title={item.title}
            summary="Acceso directo desde la ruta."
            href={`/biblioteca/${item.slug}`}
            ctaLabel="Leer"
          />
        ))}
      </div>
    </section>
  )}
</PageShell>
