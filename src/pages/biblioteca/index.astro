---
import CollectionCard from "../../components/CollectionCard.astro";
import PageShell from "../../layouts/PageShell.astro";
import { getCollection } from "astro:content";
import { getTierLabel, sortEntriesByDateDesc } from "../../utils/content";

const sorted = sortEntriesByDateDesc(await getCollection("articles"));
const categoryParam = Astro.url.searchParams.get("category");
const tierParam = Astro.url.searchParams.get("tier");
const categories = Array.from(new Set(sorted.map((entry) => entry.data.category)));
const tiers = Array.from(new Set(sorted.map((entry) => entry.data.tier)));
const categoryFilter = categories.includes(categoryParam ?? "") ? categoryParam : "";
const tierFilter = tiers.includes(tierParam ?? "") ? tierParam : "";
const filtered = sorted.filter((entry) => {
  if (categoryFilter && entry.data.category !== categoryFilter) return false;
  if (tierFilter && entry.data.tier !== tierFilter) return false;
  return true;
});
---

<PageShell
  title="Biblioteca"
  description="Biblioteca viva de ensayos, efemerides y piezas conectadas al presente."
  eyebrow="Biblioteca"
  heading="Archivo consultable"
  summary="Ruta por categorias y niveles. El archivo completo se abre a partir de Piquero."
>
  <Fragment slot="header">
    <div class="meta">
      <strong>Filtrar por categoria</strong>
      <a class="badge" href="/biblioteca">Todas</a>
      {categories.map((category) => (
        <a
          class="badge"
          href={`/biblioteca?category=${category}${tierFilter ? `&tier=${tierFilter}` : ""}`}
        >
          {category}
        </a>
      ))}
    </div>
    <div class="meta">
      <strong>Filtrar por nivel</strong>
      <a class="badge" href="/biblioteca">Todos</a>
      {tiers.map((tier) => (
        <a
          class="badge"
          href={`/biblioteca?tier=${tier}${categoryFilter ? `&category=${categoryFilter}` : ""}`}
        >
          {getTierLabel(tier)}
        </a>
      ))}
    </div>
    {(categoryFilter || tierFilter) && (
      <div class="meta">
        <span class="muted">
          Filtro activo: {categoryFilter || "todas"} / {tierFilter ? getTierLabel(tierFilter) : "todos"}
        </span>
        <a class="btn btn-ghost" href="/biblioteca">Limpiar</a>
      </div>
    )}
  </Fragment>
  <section class="section">
    <div class="grid">
      {filtered.map((entry) => (
        <CollectionCard
          meta={`${entry.data.category} - ${getTierLabel(entry.data.tier)} - ${entry.data.date}`}
          title={entry.data.title}
          summary={entry.data.summary}
          href={`/biblioteca/${entry.id}`}
          ctaLabel="Leer"
        />
      ))}
    </div>
  </section>
</PageShell>
