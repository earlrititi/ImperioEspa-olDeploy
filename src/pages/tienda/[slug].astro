---
import PageShell from "../../layouts/PageShell.astro";
import { getCollection, render } from "astro:content";

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getCollection("drops");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<PageShell
  title={entry.data.title}
  description={entry.data.seoDescription ?? entry.data.summary}
  heading={entry.data.title}
  summary={entry.data.summary}
  summaryMuted
  narrow
>
  <div slot="meta" class="meta">
    <span class="badge">{entry.data.status}</span>
    <span>{entry.data.date}</span>
  </div>

  <div slot="header">
    <p><strong>{entry.data.price}</strong></p>
  </div>

  <section class="section content">
    <Content />
  </section>

  <section class="section content">
    <div class="notice">
      <strong>Checkout seguro con Stripe.</strong>
      {entry.data.paymentLink ? (
        <div>
          <p class="muted">Pago directo en Stripe Checkout.</p>
          <a class="btn btn-primary" href={entry.data.paymentLink}>
            Comprar con Stripe
          </a>
        </div>
      ) : (
        <div>
          <p class="muted">
            ASUNCION: el enlace de pago se activa cuando el drop este listo.
          </p>
          <a class="btn btn-primary" href="/contacto">Avisame del drop</a>
        </div>
      )}
    </div>
  </section>
</PageShell>
