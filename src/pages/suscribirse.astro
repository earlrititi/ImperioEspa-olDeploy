---
import PageShell from "../layouts/PageShell.astro";
---

<PageShell
  title="Suscribirse"
  description="Elige tu acceso a Imperio Espanol: Piquero, Arcabucero o Maestre de Campo."
  eyebrow="Acceso"
  heading="Elige tu acceso"
  summary="Accede al archivo, las cronicas completas y las rutas de lectura. El pago se procesa de forma segura en Stripe Checkout."
>
  <section class="section">
    <div class="grid subscribe-grid">
      <article class="card subscribe-card">
        <span class="badge">Gratis</span>
        <h2>PIQUERO</h2>
        <p class="muted">Entrada gratuita al circulo de lectores.</p>
        <p>Manifiesto, contenido gratuito ampliado y newsletter basica.</p>
        <a class="btn btn-ghost" href="/registro">Crear cuenta gratis</a>
      </article>

      <article class="card subscribe-card">
        <span class="badge">3 EUR / mes</span>
        <h2>ARCABUCERO</h2>
        <p class="muted">Archivo completo, cronicas premium y rutas de lectura.</p>
        <p>El primer nivel de pago para sostener el proyecto y abrir el archivo.</p>
        <button class="btn btn-primary" type="button" data-plan="arcabucero-monthly">
          Suscribirme
        </button>
      </article>

      <article class="card subscribe-card">
        <span class="badge">6 EUR / mes</span>
        <h2>MAESTRE DE CAMPO</h2>
        <p class="muted">Acceso superior, ventajas reservadas y prioridad futura.</p>
        <p>La capa completa para quienes quieren implicarse con mas profundidad.</p>
        <button class="btn btn-primary" type="button" data-plan="maestre-campo-monthly">
          Suscribirme
        </button>
      </article>
    </div>
    <p class="muted subscribe-status" id="checkout-status" role="status" aria-live="polite"></p>
  </section>
</PageShell>

<script>
  const buttons = document.querySelectorAll("button[data-plan]");
  const status = document.getElementById("checkout-status");

  const setStatus = (message) => {
    if (status) {
      status.textContent = message;
    }
  };

  buttons.forEach((button) => {
    button.addEventListener("click", async () => {
      const plan = button.getAttribute("data-plan");
      const originalText = button.textContent || "Suscribirme";

      button.setAttribute("disabled", "true");
      button.textContent = "Abriendo Stripe...";
      setStatus("");

      try {
        const response = await fetch("/api/create-checkout-session", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ plan }),
        });
        const data = await response.json().catch(() => ({}));

        if (data.url) {
          window.location.href = data.url;
          return;
        }

        setStatus(data.error || "No se pudo iniciar el pago.");
      } catch (error) {
        console.error(error);
        setStatus("No se pudo iniciar el pago.");
      } finally {
        button.removeAttribute("disabled");
        button.textContent = originalText;
      }
    });
  });
</script>

<style>
  .subscribe-grid {
    align-items: stretch;
  }

  .subscribe-card {
    display: grid;
    gap: var(--space-2);
    align-content: start;
  }

  .subscribe-card .btn {
    align-self: end;
    margin-top: var(--space-2);
  }

  .subscribe-card button:disabled {
    cursor: wait;
    opacity: 0.62;
  }

  .subscribe-status {
    margin-top: var(--space-3);
  }
</style>
